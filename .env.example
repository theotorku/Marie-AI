# Anthropic API key — used by the backend proxy only (never exposed to the browser)
CLAUDE_API_KEY=sk-ant-your-key-here

# JWT secret for user authentication — use a long random string
JWT_SECRET=change-me-to-a-random-secret

# Supabase — get these from your project's Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# n8n — webhook base URL is stored per-user in the DB (no env var needed)
# Users configure their n8n webhook URL in Settings > Integrations

# Stripe — get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...   # Price ID for the $29/mo Professional plan (create product in Stripe Dashboard)
APP_URL=http://localhost:5173

# Slack — create app at https://api.slack.com/apps
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret
